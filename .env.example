# Backend
APP_NAME=Sales Insight Automator API
ENVIRONMENT=development
MAX_FILE_SIZE_MB=5
MAX_ROWS=20000
ALLOWED_ORIGINS=http://localhost:5173

# Optional API key protection for /api/summarize
API_KEY=

# LLM provider (Groq)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# SMTP for email delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com
SMTP_USE_TLS=true
